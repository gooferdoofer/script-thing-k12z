statusScript1 = 0;
IDGrab = () => {
  f=indexedDB.open('firebaseLocalStorageDb');
  f.onerror=e=>{
    console.error('Error opening DB:',e)
  };
  f.onsuccess=e=>{
    d=e.target.result;t=d.transaction(["firebaseLocalStorage"]);
    o=t.objectStore("firebaseLocalStorage");
    a=o.get('firebase:authUser:AIzaSyBiA_uzPP_ME10V_aZTwsZbKFE5gqTfKec:[DEFAULT]');
    a.onerror=e=>{
      console.error('Error getting key:',e)
    };a.onsuccess=e=>{
      ID = a.result.value.stsTokenManager.accessToken
    }
  }
};
