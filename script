Status=()=>{
  if (statusScript1 == 0) {
    idstatus = setInterval(()=>{fetch("https://zone-internal.k12.com/api/user-status", {"headers": {"accept": "application/json, text/plain, */*","accept-language": "en-US,en;q=0.9","authorization": ID,"content-type": "application/json","priority": "u=1, i","sec-ch-ua-mobile": "?0","sec-ch-ua-platform": "\"Windows\"","sec-fetch-dest": "empty","sec-fetch-mode": "cors","sec-fetch-site": "same-site","Referer": "https://zone.k12.com/"  },  "body": "{\"status\":\"" + ['AVAILABLE','BUSY','DO_NOT_DISTURB','OFFLINE'][Math.min(Math.floor(Math.random()*5),4)] + "\"}",  "method": "PATCH"});}, 100);
    statusScript1=1
  } else if (statusScript1 == 1) {
    clearInterval(idstatus),statusScript1 = 0
  }
};
